# ============================================================
# 腾讯云 Pages 部署配置说明
# ============================================================
# 本项目为纯静态站点，不包含后端服务。
# 所有 NUXT_PUBLIC_* 变量在构建时注入前端代码，只放非敏感信息。
# API Key 绝不能放在这里——应该放在你的 API 代理服务器上。
#
# 部署步骤：
# 1. 在腾讯云 Pages 控制台 → 环境变量，添加以下变量
# 2. NUXT_PUBLIC_AI_API_BASE 填写你的代理地址（代理持有 API Key）
# 3. 触发重新构建，变量会在 nuxi generate 时注入
# ============================================================

# AI 代理地址 — 指向一个兼容 OpenAI 接口的代理服务
# 代理服务负责鉴权和转发，API Key 只存在于代理服务端
# 示例：https://your-proxy.example.com/v1/chat/completions
NUXT_PUBLIC_AI_API_BASE=

# AI 模型名称 — 代理服务支持的模型标识
# 示例：minimax-m2.7-awq
NUXT_PUBLIC_AI_MODEL=

# 兼容旧配置名。如果腾讯云中已经填了 NUXT_PUBLIC_AI_MODE，也会被当成模型名称读取。
NUXT_PUBLIC_AI_MODE=

# 不推荐：公开前端 API Key 会暴露给访问者。仅在你明确接受直连模型接口风险时使用。
NUXT_PUBLIC_AI_API_KEY=

# QQ 音乐公开歌单 ID
NUXT_PUBLIC_QQ_PLAYLIST_ID=

# 默认主题：system | light | dark
NUXT_PUBLIC_DEFAULT_THEME=system
